# Copy to .env and fill in. Never commit the real .env.
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Optional locally (lookups work without it). For the full loop:
#   local quick test:  sqlite:///./local.db
#   Azure SQL:         mssql://USERNAME:PASSWORD@telcansql.database.windows.net:1433/DBNAME
DATABASE_URL=

# Barcode lookup source: auto (TELCAN first, Shopify fallback) | db | api
#BARCODE_LOOKUP=auto

# Show the Print button on every device (iPad included), not just pages
# opened with ?printer=1. Flip to true when you want remote printing.
#ALLOW_REMOTE_PRINT=false

# Optional shared secret; if set, print_agent.py must be started with
# --agent-key matching this value.
#PRINT_AGENT_KEY=

# Optional default app URL for print_agent.py when you don't want to pass
# --app every time. Use your hosted Shopify app URL here.
#PRINT_AGENT_APP_URL=https://your-app.azurewebsites.net
